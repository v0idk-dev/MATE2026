{
  "name": "mate-2026-robot-controller",
  "version": "0.1.1",
  "buildNumber": 51,
  "description": "MATE 2026 ROV Control System for SFS Robotics",
  "author": "Dogukan Koc",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --mac --arm64",
    "build:dev": "electron-builder build --mac --arm64 --config.mac.identity=null",
    "pack": "electron-builder --dir --arm64"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^40.6.1",
    "electron-builder": "^24.13.3",
    "node-gyp": "^12.3.0"
  },
  "build": {
    "appId": "dev.v0idk.mate2026",
    "productName": "MATE 2026 Robot Controller",
    "copyright": "Copyright © 2026 Dogukan Koc",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "provisioningProfile": null,
      "darkModeSupport": true
    },
    "dmg": {
      "title": "MATE 2026 Robot Controller v${version}",
      "icon": "build/icon.icns",
      "format": "UDZO",
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 130,
          "y": 130
        },
        {
          "x": 410,
          "y": 130,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 448
      }
    },
    "extraResources": [
      {
        "from": "app/Resources",
        "to": "app/Resources",
        "filter": [
          "**/*",
          "!**/*.a",
          "!**/3rdparty/**"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*",
          "!**/.DS_Store"
        ]
      },
      {
        "from": "web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "outputs",
        "to": "outputs",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "cameras.json",
      "native/settings/build/Release/settings.node",
      "native/settings/build/Release/libSettingsUI.dylib",
      "!**/node_modules/**/*",
      "!**/.git/**/*",
      "!**/dist/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dylib",
      "app/Resources/**/*",
      "scripts/**/*",
      "web/**/*",
      "models/**/*"
    ]
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fontsource/space-mono": "^5.2.9",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  }
}
